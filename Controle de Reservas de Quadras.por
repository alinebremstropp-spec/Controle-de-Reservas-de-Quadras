programa {
  funcao inicio() {
    cadeia nome, quadra
    inteiro horario = 0, opcao = 0
    logico reservada = falso

    enquanto(opcao != 5){
    escreva("\n----CONTROLE DE RESERVA DE QUADRAS----")
    escreva("\n1- Reserva")
    escreva("\n2- Consultar reserva")
    escreva("\n3- Cancelar reserva ")
    escreva("\n4- Ver disponibilidade")
    escreva("\n5- Sair")
    escreva("Escolha uma opção: ")
    leia(opcao)
    }
  }
}
